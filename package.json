{
  "name": "a2discord",
  "version": "0.1.0",
  "description": "Discord transport adapter for A2A agents",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit/",
    "test:integration": "vitest run tests/integration/",
    "test:e2e": "bun run tests/e2e/harness.ts",
    "test:watch": "vitest",
    "lint": "eslint src/"
  },
  "license": "MIT",
  "dependencies": {
    "discord.js": "^14.18.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.0.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0"
  }
}
